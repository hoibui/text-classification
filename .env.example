# Project Configuration
PROJECT_NAME=text_classification
PROJECT_ROOT=/path/to/your/text-classification

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mlops
DB_USER=your_username
DB_PASSWORD=your_password

# MLflow Configuration
MLFLOW_TRACKING_URI=postgresql://your_username:your_password@localhost:5432/mlflow_tracking
MLFLOW_EXPERIMENT_NAME=text_classification
MLFLOW_RUN_NAME=text_classification_training

# Model Configuration
MODEL_SAVE_PATH=models
MODEL_NAME_PREFIX=best_model

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=4

# Monitoring Configuration
MONITORING_ENABLED=true
MONITORING_LOG_LEVEL=INFO
MONITORING_METRICS_PORT=8080

# Training Configuration
DATA_PATH=data/train.csv
TEST_SIZE=0.2
RANDOM_STATE=42
CV_FOLDS=5

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/training.log