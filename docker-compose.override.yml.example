# Local development overrides - copy this to docker-compose.override.yml
# This file allows individual developers to customize docker-compose settings
# without affecting the main docker-compose.yml

version: '3.8'

services:
  text-classifier:
    # Uncomment and modify these settings as needed for local development
    ports:
      - "${API_PORT:-8000}:${API_PORT:-8000}"
    volumes:
      # Mount source code for hot reloading during development
      - ./src:/app/src
      - ./config.yaml:/app/config.yaml
      - ./.env:/app/.env
    environment:
      # Add any local development environment overrides here
      # - LOG_LEVEL=DEBUG
      - DB_HOST=${DB_HOST:-host.docker.internal}

    # Uncomment for development with auto-reload
    # command: python -m uvicorn src.api:app --host 0.0.0.0 --port ${API_PORT:-8000} --reload

  mlflow:
    environment:
      # Use local database settings from .env
      - DB_HOST=${DB_HOST:-host.docker.internal}
    # Override command if needed for local development
    # command: >
    #   sh -c "pip install mlflow psycopg2-binary &&
    #          mlflow server --host 0.0.0.0 --port 5000 --backend-store-uri postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST:-host.docker.internal}:${DB_PORT}/mlflow_tracking --default-artifact-root ./mlruns"

# Example: Override database connection to use localhost instead of Docker internal networking
# Uncomment and modify as needed:
#
# services:
#   text-classifier:
#     environment:
#       - DB_HOST=localhost
#   mlflow:
#     environment:
#       - DB_HOST=localhost